{
  "name": "lorekeeper-backend",
  "version": "1.0.0",
  "description": "LoreKeeper - Backend REST/gRPC Bridge",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "proto:gen": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./src/proto --grpc_out=grpc_js:./src/proto --proto_path=../grpc/proto ../grpc/proto/rag_service.proto && grpc_tools_node_protoc_ts --ts_out=grpc_js:./src/proto --proto_path=../grpc/proto ../grpc/proto/rag_service.proto"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@grpc/grpc-js": "^1.10.3",
    "@grpc/proto-loader": "^0.7.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
